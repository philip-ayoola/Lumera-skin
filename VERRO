<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>VÉRRO – Men's Luxury Perfume</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI', sans-serif;
    }

    body {
        background: linear-gradient(135deg, #f7f3ea, #e9dfd1, #d8cbb8);
        color: #1d1d1d;
    }

    /* NAVBAR */
    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 70px;
        position: sticky;
        top: 0;
        background: rgba(255,255,255,0.6);
        backdrop-filter: blur(10px);
        z-index: 10;
    }

    .logo {
        font-size: 26px;
        font-weight: bold;
        letter-spacing: 4px;
        color: #4a2f1b;
    }

    nav a {
        margin-left: 20px;
        text-decoration: none;
        color: #333;
        font-weight: 500;
    }

    nav a:hover {
        color: #8a5a2b;
    }

    /* HERO */
    .hero {
        display: grid;
        grid-template-columns: 1fr 1fr;
        padding: 80px 70px;
        align-items: center;
        gap: 40px;
    }

    .hero-text h1 {
        font-size: 60px;
        color: #4a2f1b;
        line-height: 1.1;
    }

    .hero-text p {
        margin: 20px 0;
        font-size: 16px;
        color: #444;
        line-height: 1.6;
    }

    .btn {
        padding: 12px 28px;
        background: #4a2f1b;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: 0.3s;
    }

    .btn:hover {
        transform: scale(1.05);
        background: #2f1d12;
    }

    /* HERO IMAGE */
    .hero-img img {
        width: 100%;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }

    /* SECTION */
    .section {
        padding: 60px 70px;
        text-align: center;
    }

    .section h2 {
        font-size: 32px;
        margin-bottom: 30px;
        color: #4a2f1b;
    }

    /* GRID */
    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 25px;
    }

    .card {
        background: rgba(255,255,255,0.6);
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

    .card:hover {
        transform: translateY(-10px);
    }

    .card h3 {
        margin-bottom: 10px;
        color: #5a3a20;
    }

    /* PRODUCT */
    .product {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 50px;
        padding: 60px 70px;
        flex-wrap: wrap;
    }

    .product img {
        width: 220px;
        filter: drop-shadow(0 10px 20px rgba(0,0,0,0.25));
    }

    /* FOOTER */
    footer {
        text-align: center;
        padding: 30px;
        color: #666;
    }
</style>
</head>

<body>

<header>
    <div class="logo">VÉRRO</div>
    <nav>
        <a href="#">Home</a>
        <a href="#">Notes</a>
        <a href="#">Bottle</a>
        <a href="#">Contact</a>
    </nav>
</header>

<!-- HERO SECTION -->
<section class="hero">

    <div class="hero-text">
        <h1>Command Your Presence</h1>
        <p>
            VÉRRO is a luxury fragrance for men who lead without asking for attention.
            A bold mix of amber, leather, citrus, and deep woods.
        </p>
        <button class="btn">Explore Fragrance</button>
    </div>

    <!-- Athletic masculine model holding perfume (luxury ad style) -->
    <div class="hero-img">
        <img src="https://images.unsplash.com/photo-1600180758890-6b94519a8ba6?auto=format&fit=crop&w=800&q=80"
        alt="Male Model Spraying Perfume">
    </div>

</section>

<!-- FRAGRANCE NOTES -->
<section class="section">
    <h2>Fragrance Composition</h2>

    <div class="grid">
        <div class="card">
            <h3>Top Notes</h3>
            <p>Bergamot • Lemon • Pink Pepper</p>
        </div>

        <div class="card">
            <h3>Heart Notes</h3>
            <p>Lavender • Sage • Cardamom</p>
        </div>

        <div class="card">
            <h3>Base Notes</h3>
            <p>Amber • Leather • Sandalwood</p>
        </div>
    </div>
</section>

<!-- PRODUCT SHOWCASE -->
<section class="product">

    <div>
        <h2 style="color:#4a2f1b; margin-bottom:10px;">Signature Bottle</h2>
        <p style="max-width:300px; color:#444;">
            Designed with dark glass and gold accents to represent dominance, elegance, and power.
        </p>
    </div>

    <!-- Perfume bottle image -->
    <img src="https://images.unsplash.com/photo-1615634260167-c8cdede054de?auto=format&fit=crop&w=600&q=80"
    alt="Perfume Bottle">

</section>

<footer>
    © 2026 VÉRRO Luxury Fragrance. All Rights Reserved.
</footer>

<script>
    document.querySelector(".btn").addEventListener("click", () => {
        alert("Welcome to VÉRRO — Luxury begins with presence.");
    });
</script>

</body>
</html>
